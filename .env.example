# DeepSeek Agent OS local environment example.
# Copy to .env only for local shells that load env files. Do not commit .env.

# Optional. Enables DeepSeek-backed Operations Briefing synthesis when the
# selected large-model provider is DeepSeek.
DEEPSEEK_API_KEY=

# Optional. Override only if DeepSeek-compatible endpoint routing is needed.
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# Optional. ChatGPT/Codex Computer Use and native NetworkSearch bridge routes
# use an external loopback HTTP bridge in v0.1-alpha.
# DEEPSEEK_AGENT_OS_CODEX_BRIDGE_TRANSPORT=http
# DEEPSEEK_AGENT_OS_CODEX_BRIDGE_URL=http://127.0.0.1:47329
