# DeepSeek Agent OS local environment example.
# Copy to .env only for local shells that load env files. Do not commit .env.

# Optional. Enables DeepSeek-backed Operations Briefing synthesis when the
# selected large-model provider is DeepSeek.
DEEPSEEK_API_KEY=

# Optional. Override only if DeepSeek-compatible endpoint routing is needed.
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# Optional. Used only by `pnpm test:deepseek` local smoke tests.
# DEEPSEEK_SMOKE_MODEL=deepseek-chat

# Optional. Used only by `pnpm test:deepseek:briefing` local workflow smoke tests.
# The bundled evidence folder is SMOKE SAMPLE evidence for local verification only.
# Replace before operational use when pointing the workflow at real business evidence.
# DEEPSEEK_BRIEFING_SMOKE_MODEL=deepseek-chat
# DEEPSEEK_BRIEFING_EVIDENCE_DIR=docs/templates/operations-briefing-smoke-evidence
# DEEPSEEK_BRIEFING_SMOKE_MAX_TOKENS=900

# Optional. Local bridge routes can enable screen inspection, computer control,
# and source-linked web search when a supported loopback bridge is running.
# DEEPSEEK_AGENT_OS_BRIDGE_TRANSPORT=http
# DEEPSEEK_AGENT_OS_BRIDGE_URL=http://127.0.0.1:47329
